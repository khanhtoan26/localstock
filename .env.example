# Supabase PostgreSQL
# Get from: Supabase Dashboard → Settings → Database → Connection string (URI)
# Port 6543 = transaction pooling (PgBouncer) — for application connections
DATABASE_URL=postgresql+asyncpg://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?prepared_statement_cache_size=0
# Port 5432 = session mode — for Alembic migrations
DATABASE_URL_MIGRATION=postgresql+asyncpg://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# vnstock
VNSTOCK_SOURCE=VCI

# Crawl settings
CRAWL_DELAY_SECONDS=1.0
CRAWL_BATCH_SIZE=50

# Logging
LOG_LEVEL=INFO

# Ollama LLM (optional — system works without it, just no AI features)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b-instruct-q4_K_M
OLLAMA_TIMEOUT=120
OLLAMA_KEEP_ALIVE=30m

# Scoring Weights (must sum to 1.0)
SCORING_WEIGHT_TECHNICAL=0.30
SCORING_WEIGHT_FUNDAMENTAL=0.30
SCORING_WEIGHT_SENTIMENT=0.20
SCORING_WEIGHT_MACRO=0.20

# Funnel Settings
FUNNEL_TOP_N=50
SENTIMENT_ARTICLES_PER_STOCK=5
SENTIMENT_LOOKBACK_DAYS=7

# Report Generation
REPORT_TOP_N=20
REPORT_MAX_TOKENS=4096

# SSL (set to false if behind corporate proxy)
SSL_VERIFY=true

# Telegram Notifications (leave empty to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Scheduler (daily pipeline time in VN timezone)
SCHEDULER_RUN_HOUR=15
SCHEDULER_RUN_MINUTE=45

# Score Change Alert threshold (%)
SCORE_CHANGE_THRESHOLD=15.0
